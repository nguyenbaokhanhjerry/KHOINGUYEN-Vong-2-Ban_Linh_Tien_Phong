<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml — Project DNA
  TODO: Thay toàn bộ "https://your-domain.vn" bằng domain thật trước khi deploy.
  Submit qua Google Search Console sau khi deploy:
    https://search.google.com/search-console → Sitemaps → nhập "sitemap.xml"
-->
<urlset
  xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
  xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
>

  <!-- =====================================================================
       Trang chủ (kiến trúc 1 file / SPA hiện tại)
       Khi tách thành /vi/ /en/ /jp/ riêng, tạo thêm <url> cho từng route
       và cập nhật href bên dưới trỏ về URL thật của từng phiên bản.
       ===================================================================== -->
  <url>
    <loc>https://your-domain.vn/</loc>
    <lastmod>2026-07-09</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>

    <!-- hreflang alternate — Googlebot nhận biết 3 phiên bản ngôn ngữ -->
    <xhtml:link rel="alternate" hreflang="vi"        href="https://your-domain.vn/" />
    <xhtml:link rel="alternate" hreflang="en"        href="https://your-domain.vn/" />
    <xhtml:link rel="alternate" hreflang="ja"        href="https://your-domain.vn/" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://your-domain.vn/" />

    <!-- TODO: Bỏ comment sau khi có ảnh OG thật -->
    <!--
